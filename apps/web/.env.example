# Web Dashboard Environment Variables
# Copy to .env.local and adjust as needed.

# Enable demo/showroom mode with realistic mock data (true/false)
NEXT_PUBLIC_DEMO_MODE=false

# Backend API URL
# Staging: https://api.stage.freezenith.com
# Production: https://api.freezenith.com
NEXT_PUBLIC_API_URL=https://api.freezenith.com

# Landing page URL (used in demo banner link)
# Staging: https://stage.freezenith.com
# Production: https://freezenith.com
NEXT_PUBLIC_LANDING_URL=https://freezenith.com

# Zenith mode: standalone or cloud
NEXT_PUBLIC_ZENITH_MODE=standalone
