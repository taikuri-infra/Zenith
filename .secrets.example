# Harbor Registry
HARBOR_HOST=registry.stage.freezenith.com
HARBOR_ROBOT_USER=robot$zenith-stage+ci-push
HARBOR_ROBOT_TOKEN=

# Hetzner + Cloudflare (for Terraform)
HCLOUD_TOKEN=
CLOUDFLARE_API_TOKEN=

# GitHub
GITHUB_TOKEN=

# Kubeconfig (base64 encoded)
# Generate: cat ~/.kube/zenith-staging.yaml | base64 | tr -d '\n'
KUBECONFIG_STAGING=

# Terraform variables for staging-k8s
TF_VAR_registry_host=registry.stage.freezenith.com
TF_VAR_registry_username=robot$zenith-stage+ci-push
TF_VAR_registry_password=
TF_VAR_jwt_secret=
TF_VAR_admin_email=admin@freezenith.com
TF_VAR_admin_password=
TF_VAR_db_password=
