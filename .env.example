# Zenith — Environment Configuration
# Copy this file to .env and fill in the values.

# Required: Secret key for JWT token signing (min 32 chars)
JWT_SECRET=

# Admin credentials (created on first run)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme

# Database password
DB_PASSWORD=zenith

# Object storage (RustFS, self-hosted, S3-compatible — works on any server/provider)
S3_ACCESS_KEY=zenith
S3_SECRET_KEY=changeme123
S3_REGION=us-east-1
S3_PLATFORM_BUCKET=zenith-platform-storage

# --- Production: your own domain + automatic HTTPS ---
# Point your domain's DNS at this server, set the values below, then run:
#   docker compose --profile tls up -d
# Traefik fetches a Let's Encrypt certificate automatically. Everything is served
# from one domain (dashboard at /, API at /api/*).
# ZENITH_DOMAIN=app.example.com
# ACME_EMAIL=you@example.com
# NEXT_PUBLIC_API_URL=https://app.example.com
# CORS_ORIGINS=https://app.example.com

# Resend API key (for email verification, password reset)
RESEND_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
