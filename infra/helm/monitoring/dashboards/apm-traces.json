{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "uid": "apm-traces",
  "title": "APM — Traces & Service Health",
  "tags": ["apm", "tempo", "traces", "zenith"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m"] },
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "zenith-api", "value": "zenith-api" },
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "name": "service",
        "options": [],
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "type": "query",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "RED Metrics (Rate / Errors / Duration)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "title": "Request Rate",
      "description": "HTTP requests per second",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"zenith-api\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "title": "Error Rate",
      "description": "Percentage of 5xx responses",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"zenith-api\",code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"zenith-api\"}[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "title": "P95 Latency",
      "description": "95th percentile request duration",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "title": "Active Requests",
      "description": "Currently in-flight requests",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(http_server_active_requests{job=\"zenith-api\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "title": "Request Rate by Status",
      "description": "HTTP request rate broken down by response code",
      "type": "timeseries",
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(http_requests_total{job=\"zenith-api\"}[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "title": "Latency Percentiles",
      "description": "p50, p90, p95, p99 request duration",
      "type": "timeseries",
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "D"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 8,
      "title": "Top Endpoints",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 9,
      "title": "Top Endpoints by Request Rate",
      "description": "Busiest API endpoints",
      "type": "barchart",
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "topk(15, sum by (handler) (rate(http_requests_total{job=\"zenith-api\"}[5m])))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 10,
      "title": "Slowest Endpoints (P95)",
      "description": "Highest latency API endpoints",
      "type": "barchart",
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"zenith-api\"}[5m]))) * 1000)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 11,
      "title": "Distributed Traces (Tempo)",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "id": 12,
      "title": "Recent Traces",
      "description": "Search and explore distributed traces from zenith-api",
      "type": "traces",
      "targets": [
        {
          "queryType": "nativeSearch",
          "serviceName": "zenith-api",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 13,
      "title": "Go Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 14,
      "title": "Memory Usage",
      "description": "Go heap memory allocation",
      "type": "timeseries",
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes{job=\"zenith-api\"}",
          "legendFormat": "heap alloc",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_sys_bytes{job=\"zenith-api\"}",
          "legendFormat": "heap sys",
          "refId": "B"
        },
        {
          "expr": "go_memstats_stack_inuse_bytes{job=\"zenith-api\"}",
          "legendFormat": "stack inuse",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 15,
      "title": "Goroutines & GC",
      "description": "Active goroutines and GC pauses",
      "type": "timeseries",
      "targets": [
        {
          "expr": "go_goroutines{job=\"zenith-api\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        },
        {
          "expr": "rate(go_gc_duration_seconds_count{job=\"zenith-api\"}[5m])",
          "legendFormat": "GC cycles/s",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "refresh": "30s"
}
