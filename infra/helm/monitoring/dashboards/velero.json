{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "uid": "zenith-velero",
  "title": "Velero Backup",
  "tags": ["velero", "backup", "disaster-recovery", "zenith"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": { "refresh_intervals": ["30s", "1m", "5m", "15m"] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Backup Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "title": "Successful Backups",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_success_total)", "legendFormat": "Success" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#ef4444", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "title": "Failed Backups",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_failure_total)", "legendFormat": "Failed" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#f59e0b", "value": 0 },
              { "color": "#10b981", "value": 0 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "title": "Last Successful Backup Age",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "time() - max(velero_backup_last_successful_timestamp{schedule!=\"\"} > 0)", "legendFormat": "Age" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "title": "Total Backups",
      "type": "stat",
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_total)", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "auto", "pointSize": 6 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "title": "Backup Duration Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "velero_backup_duration_seconds{phase=\"Completed\"}", "legendFormat": "{{ schedule }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "auto", "pointSize": 6 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "title": "Backup Items Count",
      "type": "timeseries",
      "targets": [
        { "expr": "velero_backup_items_total{phase=\"Completed\"}", "legendFormat": "{{ schedule }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 8,
      "title": "Restore Operations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 15 },
      "id": 9,
      "title": "Successful Restores",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_restore_success_total)", "legendFormat": "Success" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#ef4444", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 15 },
      "id": 10,
      "title": "Failed Restores",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_restore_failed_total)", "legendFormat": "Failed" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 15 },
      "id": 11,
      "title": "Total Restores",
      "type": "stat",
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_restore_total)", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#ef4444", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 15 },
      "id": 12,
      "title": "Partial Failures",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_partial_failure_total)", "legendFormat": "Partial" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 13,
      "title": "Schedule & Storage Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "#ef4444", "text": "Unavailable" }, "1": { "color": "#10b981", "text": "Available" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#10b981", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 21 },
      "id": 14,
      "title": "Backup Storage Location Status",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "velero_backup_storage_location_is_default", "legendFormat": "{{ name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#10b981", "value": 0 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 21 },
      "id": 15,
      "title": "Backup Schedule Status (Time Since Last)",
      "type": "bargauge",
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "targets": [
        { "expr": "time() - velero_backup_last_successful_timestamp{schedule!=\"\"} > 0", "legendFormat": "{{ schedule }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 16,
      "title": "Backup Success vs Failure Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(increase(velero_backup_success_total[1h]))", "legendFormat": "Success" },
        { "expr": "sum(increase(velero_backup_failure_total[1h]))", "legendFormat": "Failure" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 17,
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 18,
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{pod=~\"velero.*\"}[5m]))", "legendFormat": "{{ pod }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 19,
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{pod=~\"velero.*\"})", "legendFormat": "{{ pod }}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "templating": { "list": [] },
  "refresh": "1m"
}
