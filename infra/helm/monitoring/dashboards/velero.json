{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "uid": "velero",
  "title": "Velero Backup & Restore",
  "tags": ["velero", "backup", "disaster-recovery", "zenith"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": { "refresh_intervals": ["30s", "1m", "5m", "15m"] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Backup Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#f59e0b", "value": 0.9 },
              { "color": "#10b981", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "title": "Backup Success Rate",
      "description": "Ratio of successful backups to total attempts",
      "type": "gauge",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(velero_backup_success_total) / clamp_min(sum(velero_backup_attempt_total), 1)",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "#ef4444", "text": "Failed" },
                "1": { "color": "#10b981", "text": "Success" },
                "2": { "color": "#f59e0b", "text": "Partial Failure" },
                "3": { "color": "#3b82f6", "text": "In Progress" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#10b981", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "title": "Last Backup Status",
      "description": "Status of the most recent backup per schedule",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "velero_backup_last_status{schedule!=\"\"}",
          "legendFormat": "{{ schedule }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 86400 },
              { "color": "#ef4444", "value": 172800 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "title": "Time Since Last Successful Backup",
      "description": "Seconds elapsed since the last successful backup. Alert if >24h.",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "time() - max(velero_backup_last_successful_timestamp{schedule!=\"\"} > 0)",
          "legendFormat": "Age"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "title": "Backup Success vs Failure",
      "description": "Cumulative successful and failed backup counts over time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(increase(velero_backup_success_total[1h]))", "legendFormat": "Success" },
        { "expr": "sum(increase(velero_backup_failure_total[1h]))", "legendFormat": "Failure" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 6,
      "title": "Backup Details",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "auto", "pointSize": 5 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 7,
      "title": "Backup Items Count",
      "description": "Number of items included in each backup",
      "type": "timeseries",
      "targets": [
        { "expr": "velero_backup_items_total", "legendFormat": "{{ schedule }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "auto", "pointSize": 5 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 8,
      "title": "Backup Tarball Size",
      "description": "Size of backup tarballs per schedule",
      "type": "timeseries",
      "targets": [
        { "expr": "velero_backup_tarball_size_bytes", "legendFormat": "{{ schedule }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#ef4444", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 15 },
      "id": 9,
      "title": "Partial Failures",
      "description": "Backups that completed with partial failures",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_partial_failure_total)", "legendFormat": "Partial Failures" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#ef4444", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 15 },
      "id": 10,
      "title": "Backup Warnings",
      "description": "Total backup warnings across all schedules",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_warning_total)", "legendFormat": "Warnings" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#ef4444", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "id": 11,
      "title": "Backup Item Errors",
      "description": "Errors encountered on individual backup items",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_backup_items_errors)", "legendFormat": "Item Errors" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 12,
      "title": "Restore & Snapshots",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "Partial Failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "id": 13,
      "title": "Restore Success vs Failure",
      "description": "Restore operations broken down by outcome",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(increase(velero_restore_success_total[1h]))", "legendFormat": "Success" },
        { "expr": "sum(increase(velero_restore_failed_total[1h]))", "legendFormat": "Failed" },
        { "expr": "sum(increase(velero_restore_partial_failure_total[1h]))", "legendFormat": "Partial Failure" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "id": 14,
      "title": "CSI Snapshot Success vs Failure",
      "description": "CSI volume snapshot outcomes over time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(increase(velero_csi_snapshot_success_total[1h]))", "legendFormat": "Success" },
        { "expr": "sum(increase(velero_csi_snapshot_failure_total[1h]))", "legendFormat": "Failure" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#10b981", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "id": 15,
      "title": "Volume Snapshot Attempts",
      "description": "Total volume snapshot attempts and failures",
      "type": "stat",
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(velero_volume_snapshot_attempt_total)", "legendFormat": "Attempts" },
        { "expr": "sum(velero_volume_snapshot_failure_total)", "legendFormat": "Failures" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 16,
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 17,
      "title": "Velero CPU Usage",
      "description": "CPU usage of Velero pods",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{pod=~\"velero.*\"}[5m]))", "legendFormat": "{{ pod }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 18,
      "title": "Velero Memory Usage",
      "description": "Memory usage of Velero pods",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{pod=~\"velero.*\"})", "legendFormat": "{{ pod }}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "templating": { "list": [] },
  "refresh": "1m"
}
