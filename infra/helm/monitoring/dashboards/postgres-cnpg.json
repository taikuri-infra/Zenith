      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_deadlocks{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "deadlocks",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_conflicts{cluster=\"$cluster\"}[5m]))",
