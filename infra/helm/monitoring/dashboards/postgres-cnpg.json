{
  "uid": "postgres-cnpg",
  "title": "CNPG PostgreSQL",
  "tags": ["zenith", "postgres", "cnpg"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(cnpg_collector_up, cluster)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health & Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Database Up",
      "description": "CNPG collector status (1 = up, 0 = down)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "min(cnpg_collector_up{cluster=\"$cluster\"})",
          "legendFormat": "Health",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "description": "Total active backend connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_backends_total{cluster=\"$cluster\"})",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Database Size",
      "description": "Total database size on disk",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_pg_database_size_bytes{cluster=\"$cluster\"})",
          "legendFormat": "Total Size",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Longest Transaction",
      "description": "Duration of the longest running transaction",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 300 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(cnpg_backends_max_tx_duration_seconds{cluster=\"$cluster\"})",
          "legendFormat": "Max TX Duration",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Replication Lag",
      "description": "Replication lag in seconds (0 for primary-only clusters)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(cnpg_pg_replication_lag{cluster=\"$cluster\"}) OR vector(0)",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Waiting Backends",
      "description": "Number of backends waiting on locks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 15,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_backends_waiting_total{cluster=\"$cluster\"}) OR vector(0)",
          "legendFormat": "Waiting",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec",
      "description": "Committed and rolled-back transactions per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_xact_commit{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_xact_rollback{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows Inserted / Updated / Deleted",
      "description": "Row mutation rates across all databases",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_tup_inserted{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "inserted/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_tup_updated{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "updated/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_tup_deleted{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "deleted/s",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache & I/O",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "description": "Proportion of reads served from shared buffer cache (target > 99%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_pg_stat_database_blks_hit{cluster=\"$cluster\"}) / (sum(cnpg_pg_stat_database_blks_hit{cluster=\"$cluster\"}) + sum(cnpg_pg_stat_database_blks_read{cluster=\"$cluster\"}))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Buffer Checkpoint / Clean / Backend Writes",
      "description": "Buffers written by checkpointer, background writer, and backends",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 14,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_bgwriter_buffers_checkpoint{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "checkpoint",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_bgwriter_buffers_clean{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "bgwriter clean",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_bgwriter_buffers_backend{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "backend",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows Fetched / Returned",
      "description": "Rows fetched (by index) vs returned (by seq scan) per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 16,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_tup_fetched{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "fetched/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_tup_returned{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "returned/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "WAL & Replication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "WAL Archiving Success / Failure",
      "description": "Rate of successfully archived vs failed WAL segments",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "archived" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_archiver_archived_count{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "archived",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_archiver_failed_count{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Replication Lag",
      "description": "Replication lag over time (seconds behind primary)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 17,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
