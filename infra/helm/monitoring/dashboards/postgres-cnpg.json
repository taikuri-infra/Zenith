      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_pg_replication_lag{cluster=\"$cluster\"}",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sequential vs Index Scans",
      "description": "Total sequential scans vs index scans across all user tables",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "seq scans" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "idx scans" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_user_tables_seq_scan{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "seq scans",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_user_tables_idx_scan{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "idx scans",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Maintenance & Issues",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Dead Tuples (Needs Vacuum)",
      "description": "Dead tuples per table - high values indicate vacuum is needed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
