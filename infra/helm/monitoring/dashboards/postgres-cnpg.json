{
  "uid": "zenith-postgres-cnpg",
  "title": "PostgreSQL / CNPG",
  "description": "Deep dive into CloudNativePG clusters: keycloak-pg, free-pg, zenith-postgres",
  "tags": ["zenith", "practical"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(cnpg_collector_up, cluster)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Cluster Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Instances Up",
      "description": "Number of CNPG collector instances reporting",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_collector_up{cluster=\"$cluster\"})",
          "legendFormat": "Instances",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Role",
      "description": "0 = primary, 1 = replica",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Primary", "color": "green" }, "1": { "text": "Replica", "color": "blue" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_collector_replica_mode{cluster=\"$cluster\"}",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PostgreSQL Version",
      "description": "PostgreSQL major version as reported by CNPG",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_collector_postgres_version{cluster=\"$cluster\"}",
          "legendFormat": "PG Version",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "WAL Directory Size",
      "description": "Size of the WAL directory on disk",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_collector_pg_wal{cluster=\"$cluster\"}",
          "legendFormat": "WAL Size",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Connections",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Active Backends",
      "description": "Total active database connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 6 },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_backends_total{cluster=\"$cluster\"}",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Waiting Backends",
      "description": "Backends waiting on locks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 6 },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_backends_waiting_total{cluster=\"$cluster\"}",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Max TX Duration",
      "description": "Longest running transaction duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 6 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 300 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(cnpg_backends_max_tx_duration_seconds{cluster=\"$cluster\"})",
          "legendFormat": "Max TX Duration",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Database Size & Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 10,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Database Size",
      "description": "Total database size on disk",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_pg_database_size_bytes{cluster=\"$cluster\"}",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transactions per Second",
      "description": "Committed transactions rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_xact_commit{cluster=\"$cluster\"}[5m])",
          "legendFormat": "commits {{ datname }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_xact_rollback{cluster=\"$cluster\"}[5m])",
          "legendFormat": "rollbacks {{ datname }}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Row Operations Rate",
      "description": "Rows returned, fetched, inserted, updated, deleted per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 1,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_tup_returned{cluster=\"$cluster\"}[5m])",
          "legendFormat": "returned",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_tup_fetched{cluster=\"$cluster\"}[5m])",
          "legendFormat": "fetched",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_tup_inserted{cluster=\"$cluster\"}[5m])",
          "legendFormat": "inserted",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_tup_updated{cluster=\"$cluster\"}[5m])",
          "legendFormat": "updated",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_tup_deleted{cluster=\"$cluster\"}[5m])",
          "legendFormat": "deleted",
          "refId": "E"
        }
      ]
    },
    {
      "type": "row",
      "title": "Replication & Backup",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 14,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Active Replication Slots",
      "description": "Number of active replication slots",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 23 },
      "id": 15,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cnpg_pg_replication_slots_active{cluster=\"$cluster\"}) OR vector(0)",
          "legendFormat": "Slots",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Last Backup Age",
      "description": "Time since the last available backup",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 23 },
      "id": 16,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "red", "value": 172800 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - max(cnpg_collector_last_available_backup_timestamp{cluster=\"$cluster\"})",
          "legendFormat": "Backup Age",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "WAL Archiving OK",
      "description": "1 if WAL archiving is working, 0 if failed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 23 },
      "id": 17,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" }, "0": { "text": "FAIL", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_collector_wal_archiving_info{cluster=\"$cluster\"}",
          "legendFormat": "WAL Archive",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Replication Lag",
      "description": "Replication lag in bytes between sent and written WAL",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 23 },
      "id": 18,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_pg_stat_replication_sent_diff_bytes{cluster=\"$cluster\"} - cnpg_pg_stat_replication_write_diff_bytes{cluster=\"$cluster\"}",
          "legendFormat": "{{ application_name }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache & Buffer",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 19,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "description": "Percentage of reads served from shared buffer cache (higher is better)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cnpg_pg_stat_database_blks_hit{cluster=\"$cluster\"} / (cnpg_pg_stat_database_blks_hit{cluster=\"$cluster\"} + cnpg_pg_stat_database_blks_read{cluster=\"$cluster\"})",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Temp Files & Bytes",
      "description": "Temporary files created and bytes written",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*bytes.*" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*files.*" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_temp_bytes{cluster=\"$cluster\"}[5m])",
          "legendFormat": "temp bytes {{ datname }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cnpg_pg_stat_database_temp_files{cluster=\"$cluster\"}[5m])",
          "legendFormat": "temp files {{ datname }}",
          "refId": "B"
        }
      ]
    }
  ]
}