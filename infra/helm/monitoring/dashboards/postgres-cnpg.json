      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, cnpg_pg_stat_user_tables_n_dead_tup{cluster=\"$cluster\"})",
          "legendFormat": "{{ relname }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Temp Files & Bytes (Spilling to Disk)",
      "description": "Temporary files/bytes created when queries exceed work_mem",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*bytes.*" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*files.*" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_temp_bytes{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "temp bytes/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cnpg_pg_stat_database_temp_files{cluster=\"$cluster\"}[5m]))",
          "legendFormat": "temp files/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deadlocks & Conflicts",
      "description": "Deadlocks and query conflicts (replica recovery conflicts)",
