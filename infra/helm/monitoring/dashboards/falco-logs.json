{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "uid": "falco-logs",
  "title": "Falco Security Events",
  "tags": ["falco", "security", "loki", "zenith"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m"] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "notice" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "informational" }, "properties": [{ "id": "color", "value": { "fixedColor": "#10b981", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "emergency" }, "properties": [{ "id": "color", "value": { "fixedColor": "#dc2626", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "alert" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e11d48", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "#6b7280", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "title": "Security Events Timeline",
      "description": "Falco event volume over time, stacked by priority level",
      "type": "timeseries",
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (priority) (count_over_time({source=\"falco\"} [$__auto]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "title": "Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "notice" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "informational" }, "properties": [{ "id": "color", "value": { "fixedColor": "#10b981", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "emergency" }, "properties": [{ "id": "color", "value": { "fixedColor": "#dc2626", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "title": "Events by Priority",
      "description": "Distribution of Falco events by severity level",
      "type": "piechart",
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum by (priority) (count_over_time({source=\"falco\"} [$__auto]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barAlignment": 0
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "title": "Events by Rule",
      "description": "Top Falco rules firing the most events",
      "type": "barchart",
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (rule) (count_over_time({source=\"falco\"} [$__auto])))",
          "legendFormat": "{{rule}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "title": "Events by Namespace",
      "description": "Namespaces generating the most Falco events",
      "type": "barchart",
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (k8s_ns_name) (count_over_time({source=\"falco\"} [$__auto])))",
          "legendFormat": "{{k8s_ns_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Critical & Warning Events",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 8,
      "title": "Recent Critical Events",
      "description": "Latest critical-priority Falco security events",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{source=\"falco\", priority=\"critical\"} | json",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "id": 9,
      "title": "Recent Warning Events",
      "description": "Latest warning-priority Falco security events",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{source=\"falco\", priority=\"warning\"} | json",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 10,
      "title": "Pod Analysis & Full Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "id": 11,
      "title": "Events by Pod",
      "description": "Top pods triggering the most Falco alerts",
      "type": "barchart",
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "topk(15, sum by (k8s_pod_name) (count_over_time({source=\"falco\"} [$__auto])))",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 48 },
      "id": 12,
      "title": "Event Log Stream",
      "description": "Full stream of all Falco security events",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{source=\"falco\"} | json",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": { "list": [] },
  "refresh": "30s"
}
