        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(argocd_app_k8s_request_total[5m])) by (verb, resource_kind)",
          "legendFormat": "{{ verb }} {{ resource_kind }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cluster Cache Hits vs Misses",
      "description": "Kubernetes cluster API cache hit/miss ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 15,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*hit.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*miss.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(argocd_cluster_api_resource_actions[5m])) by (action)",
          "legendFormat": "{{ action }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Reconciliation & Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 16,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "App Reconciliation Rate",
      "description": "Rate of application reconciliation operations",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 17,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(argocd_app_reconcile_count[5m])) by (namespace)",
          "legendFormat": "{{ namespace }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Reconciliation Duration (p95)",
      "description": "95th percentile reconciliation duration across all apps",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 32 },
      "id": 18,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(argocd_app_reconcile_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Reconciliation Duration (p50)",
      "description": "Median reconciliation duration across all apps",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 32 },
      "id": 19,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(argocd_app_reconcile_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "ArgoCD Resource Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 20,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "ArgoCD CPU Usage",
      "description": "CPU usage of ArgoCD components",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
