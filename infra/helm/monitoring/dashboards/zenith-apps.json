    {
      "type": "row",
      "title": "CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 7,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage by Container",
      "description": "CPU usage for zenith-staging containers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 1,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"zenith-staging\",container!=\"\"}[5m])",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage by Container",
      "description": "Memory working set for zenith-staging containers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 1,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_working_set_bytes{namespace=\"zenith-staging\",container!=\"\"}",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pod Restarts",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 10,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Container Restarts (last 1h)",
      "description": "Number of container restarts in the last hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 80,
            "showPoints": "never",
            "spanNulls": true,
            "lineWidth": 1,
            "gradientMode": "scheme",
            "axisPlacement": "auto",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"zenith-staging\"}[1h])",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Deployment Replica Mismatch",
      "description": "Deployments where desired replicas do not match available replicas",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "instance": true, "job": true, "uid": true },
            "renameByName": { "deployment": "Deployment", "namespace": "Namespace", "Value": "Mismatch" }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_spec_replicas{namespace=\"zenith-staging\"} - kube_deployment_status_replicas_available{namespace=\"zenith-staging\"} != 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Customer Apps (zenith-apps)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 13,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Running Customer Apps",
      "description": "Pods running in the zenith-apps namespace",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 23 },
      "id": 14,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kube_pod_status_phase{namespace=\"zenith-apps\",phase=\"Running\"}) OR vector(0)",
          "legendFormat": "Running Apps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Customer Apps CPU Usage",
      "description": "CPU usage for containers in zenith-apps namespace",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 23 },
      "id": 15,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
