          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(pod)(rate(container_cpu_usage_seconds_total{namespace=\"zenith-apps\",container!=\"\"}[5m]))",
          "legendFormat": "{{ pod }}",
          "refId": "A"
