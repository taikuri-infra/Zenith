{
  "name": "zenith",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:mc": "turbo dev --filter=@zenith/mission-control",
    "dev:web": "turbo dev --filter=@zenith/web",
    "build:mc": "turbo build --filter=@zenith/mission-control",
    "build:web": "turbo build --filter=@zenith/web",
    "dev:landing": "turbo dev --filter=@zenith/landing",
    "build:landing": "turbo build --filter=@zenith/landing"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "turbo": "^2.9.16",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "vite": "7.3.5",
      "minimatch": ">=9.0.7",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=2.0.3",
      "flatted": ">=3.4.2",
      "fast-uri": ">=3.1.2",
      "ws": ">=8.20.1",
      "lodash": ">=4.18.0",
      "ajv": ">=6.14.0",
      "postcss": ">=8.5.10"
    }
  }
}
